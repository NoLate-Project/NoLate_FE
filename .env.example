EXPO_PUBLIC_MAP_PROVIDER=TMAP
EXPO_PUBLIC_API_BASE_URL=http://YOUR_MAC_LAN_IP:5522
# 지도 렌더 SDK를 네이버로 유지할 경우에만 사용 (현재 앱 설정 기준)
# EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=YOUR_NAVER_MAP_CLIENT_ID
# EXPO_PUBLIC_NAVER_MAP_CLIENT_SECRET=YOUR_NAVER_MAP_CLIENT_SECRET

# Tmap Open API 앱키 (필수)
# - 주소 검색(POI): /tmap/pois
# - 정방향 지오코딩: /tmap/geo/fullAddrGeo
# - 역지오코딩: /tmap/geo/reversegeocoding
# - 자차 경로: /tmap/routes
# - 도보 경로: /tmap/routes/pedestrian
# - 대중교통 경로: /transit/routes
EXPO_PUBLIC_TMAP_APP_KEY=YOUR_TMAP_APP_KEY

# Optional
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
# EXPO_PUBLIC_NAVER_CONSUMER_KEY=YOUR_NAVER_LOGIN_CLIENT_ID
# EXPO_PUBLIC_NAVER_APP_NAME=NoLate
# EXPO_PUBLIC_NAVER_SERVICE_URL_SCHEME_IOS=nolate
